AZURE_AI_PROJECT_ENDPOINT=https://<your-hub>.services.ai.azure.com/api/projects/<your-project>
MODEL_DEPLOYMENT=gpt-54
EMBEDDING_DEPLOYMENT=text-embedding-3-large
SEARCH_ENDPOINT=https://<your-search>.search.windows.net
SEARCH_API_KEY=<your-search-api-key>
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
STORAGE_ACCOUNT_NAME=<your-storage-account>
APPLICATIONINSIGHTS_CONNECTION_STRING=<your-appinsights-connection-string>
API_KEY=<your-api-key>

# Azure Document Intelligence (required for PDF/Word upload)
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://<your-docintel>.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=<your-docintel-key>
